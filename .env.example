# Copy to .env and fill in real values. docker-compose.yml auto-loads .env for variable substitution.

# Postgres
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me
POSTGRES_DB=sar_lar_tal

# Backend (better-auth + Prisma) — DATABASE_URL/BETTER_AUTH_URL use the "db"/"backend"
# service hostnames since these run inside the Docker network
DATABASE_URL=postgresql://postgres:change-me@db:5432/sar_lar_tal
FRONTEND_URL=http://localhost:3000
BETTER_AUTH_SECRET=generate-a-random-secret
BETTER_AUTH_URL=http://localhost:3001

# Frontend — API_URL is server-side only (internal Docker DNS), NEXT_PUBLIC_API_URL is
# browser-facing and must stay host-reachable
API_URL=http://backend:3001
NEXT_PUBLIC_API_URL=http://localhost:3001
